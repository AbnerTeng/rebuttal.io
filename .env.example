# Copy to .env and fill in values

# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# Set to true for local dev without Clerk (all auth is bypassed)
SKIP_AUTH=false

# Server
PORT=3000

# Path to SQLite file — /data is the Docker volume mount point
DB_PATH=/data/rebuttals.db
