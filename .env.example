# Copy to .env and fill in values

# Required: random secret for signing session JWTs
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_secret

# Set to true to bypass all auth (useful for local dev/testing)
SKIP_AUTH=false

# Server
PORT=3000

# Path to SQLite file — /data is the Docker volume mount point
DB_PATH=/data/rebuttals.db
